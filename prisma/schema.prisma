generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id           String       @id @default(cuid())
  name         String?
  email        String       @unique
  passwordHash String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  scenarios    Scenario[]
  farmProfile  FarmProfile?
  hedges       HedgePosition[]
  contracts    GrainContract[]
}

model Scenario {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String   @default("Untitled Scenario")
  commodity       String   // 'corn' | 'soybeans'
  acres           Float
  expectedYield   Float
  costPerAcre     Float
  basisAssumption Float
  storageCost     Float    @default(0)
  desiredMargin   Float    @default(0.50)
  targetProfit    Float?
  breakEvenPrice  Float
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model FarmProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commodity       String   @default("corn")
  acres           Float    @default(1000)
  expectedYield   Float    @default(200)
  costPerAcre     Float    @default(0)
  basisAssumption Float    @default(-0.30)
  basisMode       String   @default("manual") // 'manual' | 'auto'
  zipCode         String?
  storageCost     Float    @default(0)
  desiredMargin   Float    @default(0.50)
  costBreakdown   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model HedgePosition {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bushelsHedged  Int
  contractType   String   // 'futures' | 'HTA' | 'basis' | 'option'
  action         String   @default("sell") // 'buy' | 'sell'
  entryPrice     Float
  expiration     String?
  createdAt      DateTime @default(now())

  @@index([userId])
}

model GrainContract {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contractNumber  String
  commodity       String   @default("CORN")
  type            String   @default("CASH")
  quantityBushels Int
  cashPrice       String
  saleDate        String
  deliveryStart   String
  deliveryEnd     String
  location        String
  status          String   @default("FILLED")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model Lead {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("dashboard")
  createdAt DateTime @default(now())
}

model GrainBid {
  id              String   @id @default(cuid())
  facility        String
  company         String   // Agricharts subdomain / source name
  city            String?
  state           String?
  zip             String?
  lat             Float?
  lon             Float?
  commodity       String   // 'corn' | 'soybeans'
  cashPrice       Float?
  basis           Float    // in dollars (e.g., -0.45)
  futuresContract String?  // e.g., 'ZCK26'
  deliveryStart   String?
  deliveryEnd     String?
  source          String   @default("agricharts")
  fetchedAt       DateTime @default(now())

  @@index([commodity])
  @@index([state])
}
